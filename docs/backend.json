
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the LifeTrack application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "The email address of the user.",
          "format": "email"
        },
        "displayName": {
          "type": "string",
          "description": "The chosen public name of the user."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the user account was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp when the user's profile was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "createdAt"
      ]
    },
    "SharedGroup": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SharedGroup",
      "type": "object",
      "description": "A collaborative room for shared expenses.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "createdBy": { "type": "string" },
        "creatorName": { "type": "string" },
        "memberUids": { "type": "array", "items": { "type": "string" } },
        "members": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "userId": { "type": "string" },
              "userName": { "type": "string" }
            }
          } 
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "createdBy", "memberUids", "members", "createdAt"]
    },
    "RoomExpense": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "RoomExpense",
      "type": "object",
      "description": "An expense within a shared room.",
      "properties": {
        "id": { "type": "string" },
        "roomId": { "type": "string" },
        "amount": { "type": "number" },
        "paidBy": { "type": "string", "description": "UserId of payer" },
        "paidByName": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" }, "description": "UserIds involved" },
        "splitType": { "type": "string", "enum": ["equal", "custom", "percentage"] },
        "splits": { "type": "object", "description": "Map of userId to amount" },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "roomId", "amount", "paidBy", "participants", "splitType", "splits", "createdAt"]
    },
    "RoomSettlement": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "RoomSettlement",
      "type": "object",
      "description": "A settlement payment within a room.",
      "properties": {
        "id": { "type": "string" },
        "roomId": { "type": "string" },
        "paidBy": { "type": "string", "description": "UserId of sender" },
        "paidByName": { "type": "string" },
        "paidTo": { "type": "string", "description": "UserId of receiver" },
        "paidToName": { "type": "string" },
        "amount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "roomId", "paidBy", "paidTo", "amount", "createdAt"]
    },
    "MonthlyBudget": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MonthlyBudget",
      "type": "object",
      "description": "Stores user's budget settings.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "month": { "type": "number" },
        "year": { "type": "number" },
        "totalBudgetAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profile.",
          "params": [{ "name": "userId", "description": "User UID" }]
        }
      },
      {
        "path": "/sharedGroups/{groupId}",
        "definition": {
          "entityName": "SharedGroup",
          "schema": { "$ref": "#/backend/entities/SharedGroup" },
          "description": "Collaborative split rooms.",
          "params": [{ "name": "groupId", "description": "Short code or ID" }]
        }
      },
      {
        "path": "/sharedGroups/{groupId}/expenses/{expenseId}",
        "definition": {
          "entityName": "RoomExpense",
          "schema": { "$ref": "#/backend/entities/RoomExpense" },
          "description": "Expenses in room.",
          "params": [{ "name": "groupId", "description": "Room ID" }, { "name": "expenseId", "description": "Expense ID" }]
        }
      },
      {
        "path": "/sharedGroups/{groupId}/settlements/{id}",
        "definition": {
          "entityName": "RoomSettlement",
          "schema": { "$ref": "#/backend/entities/RoomSettlement" },
          "description": "Settlements in room.",
          "params": [{ "name": "groupId", "description": "Room ID" }, { "name": "id", "description": "Settlement ID" }]
        }
      }
    ]
  }
}
