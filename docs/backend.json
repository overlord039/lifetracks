
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the LifeTrack application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "createdAt"]
    },
    "ExpenseCategory": {
      "title": "ExpenseCategory",
      "type": "object",
      "description": "Personal expense categories (labels).",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string", "description": "Encrypted category name" },
        "type": { "type": "string", "enum": ["daily", "fixed"] },
        "isPrivate": { "type": "boolean" },
        "isEncrypted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SalaryProfile": {
      "title": "SalaryProfile",
      "type": "object",
      "description": "User's financial strategy metrics.",
      "properties": {
        "userId": { "type": "string" },
        "salary": { "type": "string", "description": "Encrypted salary amount" },
        "age": { "type": "string", "description": "Encrypted age" },
        "expensePercent": { "type": "number" },
        "savingsPercent": { "type": "number" },
        "investmentPercent": { "type": "number" },
        "healthPercent": { "type": "number" },
        "personalPercent": { "type": "number" },
        "isEncrypted": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "MonthlyBudget": {
      "title": "MonthlyBudget",
      "type": "object",
      "description": "Financial targets for a specific month.",
      "properties": {
        "userId": { "type": "string" },
        "month": { "type": "number" },
        "year": { "type": "number" },
        "totalBudgetAmount": { "type": "string", "description": "Encrypted total" },
        "baseBudgetAmount": { "type": "string", "description": "Encrypted base" },
        "extraBudgetAmount": { "type": "string", "description": "Encrypted extra" },
        "isWeekendExtraBudgetEnabled": { "type": "boolean" },
        "isDailyLimitEnabled": { "type": "boolean" },
        "isEncrypted": { "type": "boolean" }
      }
    },
    "FixedExpense": {
      "title": "FixedExpense",
      "type": "object",
      "description": "Recurring monthly costs.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string", "description": "Encrypted name" },
        "amount": { "type": "string", "description": "Encrypted amount" },
        "expenseCategoryId": { "type": "string" },
        "allocationBucket": { "type": "string", "enum": ["expense", "savings", "investment", "health", "personal"] },
        "includeInBudget": { "type": "boolean" },
        "isEncrypted": { "type": "boolean" }
      }
    },
    "Debt": {
      "title": "Debt",
      "type": "object",
      "description": "E2EE Debt records.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "debtorName": { "type": "string", "description": "Encrypted name" },
        "amount": { "type": "string", "description": "Encrypted amount" },
        "description": { "type": "string", "description": "Encrypted notes" },
        "isPaid": { "type": "boolean" },
        "isEncrypted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "LearningGoal": {
      "title": "LearningGoal",
      "type": "object",
      "description": "Skill mastery targets.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "skill": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["Easy", "Medium", "Hard"] },
        "target": { "type": "number" },
        "completedCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "DailyDiary": {
      "title": "DailyDiary",
      "type": "object",
      "description": "Encrypted daily reflections.",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "description": "YYYY-MM-DD" },
        "whatIDidToday": { "type": "string", "description": "Encrypted text" },
        "whatILearned": { "type": "string", "description": "Encrypted text" },
        "challengesBlockers": { "type": "string", "description": "Encrypted text" },
        "tomorrowsPlan": { "type": "string", "description": "Encrypted text" },
        "mood": { "type": "string", "description": "Encrypted emoji" },
        "isEncrypted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SharedGroup": {
      "title": "SharedGroup",
      "type": "object",
      "description": "A collaborative room for shared expenses.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "description": "Encrypted room name" },
        "createdBy": { "type": "string" },
        "creatorName": { "type": "string" },
        "memberUids": { "type": "array", "items": { "type": "string" } },
        "members": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "userId": { "type": "string" },
              "userName": { "type": "string" }
            }
          } 
        },
        "isEncrypted": { "type": "boolean" },
        "isManual": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "RoomExpense": {
      "title": "RoomExpense",
      "type": "object",
      "description": "An expense within a shared room.",
      "properties": {
        "id": { "type": "string" },
        "roomId": { "type": "string" },
        "amount": { "type": "number" },
        "paidBy": { "type": "string" },
        "paidByName": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "splitType": { "type": "string", "enum": ["equal", "custom", "percentage"] },
        "splits": { "type": "object", "description": "userId -> amount map" },
        "expenseCategoryId": { "type": "string" },
        "description": { "type": "string" },
        "allocationBucket": { "type": "string", "enum": ["expense", "savings", "investment", "health", "personal"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "entityName": "User", "description": "User profile." } },
      { "path": "/users/{userId}/expenseCategories/{catId}", "definition": { "entityName": "ExpenseCategory", "description": "Personal labels." } },
      { "path": "/users/{userId}/salaryProfiles/current", "definition": { "entityName": "SalaryProfile", "description": "Planner data." } },
      { "path": "/users/{userId}/monthlyBudgets/{monthId}", "definition": { "entityName": "MonthlyBudget", "description": "Monthly targets." } },
      { "path": "/users/{userId}/monthlyBudgets/{monthId}/fixedExpenses/{id}", "definition": { "entityName": "FixedExpense", "description": "Recurring month costs." } },
      { "path": "/users/{userId}/monthlyBudgets/{monthId}/expenses/{expenseId}", "definition": { "entityName": "RoomExpense", "description": "Personal expenses." } },
      { "path": "/users/{userId}/debts/{debtId}", "definition": { "entityName": "Debt", "description": "Debt records." } },
      { "path": "/users/{userId}/learningGoals/{goalId}", "definition": { "entityName": "LearningGoal", "description": "Learning progress." } },
      { "path": "/users/{userId}/dailyDiaries/{date}", "definition": { "entityName": "DailyDiary", "description": "Diary entries." } },
      { "path": "/sharedGroups/{groupId}", "definition": { "entityName": "SharedGroup", "description": "Collaboration rooms." } },
      { "path": "/sharedGroups/{groupId}/expenses/{expenseId}", "definition": { "entityName": "RoomExpense", "description": "Shared bills." } }
    ]
  }
}
