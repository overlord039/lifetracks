
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the LifeTrack application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "The email address of the user.",
          "format": "email"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the user account was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp when the user's profile was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "createdAt"
      ]
    },
    "MonthlyBudget": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MonthlyBudget",
      "type": "object",
      "description": "Stores the user's overall budget settings and calculations for a specific month and year.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the MonthlyBudget entity."
        },
        "userId": {
          "type": "string",
          "description": "Reference to the User who owns this monthly budget."
        },
        "month": {
          "type": "number",
          "description": "The month number (1-12) for this budget."
        },
        "year": {
          "type": "number",
          "description": "The year for this budget."
        },
        "totalBudgetAmount": {
          "type": "number",
          "description": "The total budget amount set by the user for the month."
        },
        "isWeekendExtraBudgetEnabled": {
          "type": "boolean",
          "description": "Toggle to enable or disable extra budget for weekend days."
        },
        "saturdayExtraAmount": {
          "type": "number",
          "description": "Extra budget for Saturdays."
        },
        "sundayExtraAmount": {
          "type": "number",
          "description": "Extra budget for Sundays."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the monthly budget was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp when the monthly budget was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "month",
        "year",
        "totalBudgetAmount",
        "createdAt"
      ]
    },
    "FixedExpense": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "FixedExpense",
      "type": "object",
      "description": "Represents a recurring fixed monthly expense defined by the user.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the FixedExpense entity."
        },
        "userId": {
          "type": "string",
          "description": "Reference to the User who owns this fixed expense."
        },
        "monthlyBudgetId": {
          "type": "string",
          "description": "Reference to the MonthlyBudget this fixed expense is associated with."
        },
        "name": {
          "type": "string",
          "description": "The name of the fixed expense."
        },
        "amount": {
          "type": "number",
          "description": "The fixed amount of the expense."
        },
        "includeInBudget": {
          "type": "boolean",
          "description": "A toggle indicating whether this fixed expense should be deducted from the monthly budget calculation."
        },
        "expenseCategoryId": {
          "type": "string",
          "description": "Reference to the ExpenseCategory this fixed expense belongs to."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the fixed expense was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp when the fixed expense was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "monthlyBudgetId",
        "name",
        "amount",
        "includeInBudget",
        "expenseCategoryId",
        "createdAt"
      ]
    },
    "ExpenseCategory": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ExpenseCategory",
      "type": "object",
      "description": "Defines a user-created category for organizing expenses.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the ExpenseCategory entity."
        },
        "userId": {
          "type": "string",
          "description": "Reference to the User who owns this expense category."
        },
        "name": {
          "type": "string",
          "description": "The name of the expense category."
        },
        "type": {
          "type": "string",
          "enum": ["daily", "fixed"],
          "description": "The type of the category."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the expense category was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp when the expense category was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "name",
        "type",
        "createdAt"
      ]
    },
    "Expense": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Expense",
      "type": "object",
      "description": "Records an individual expense transaction made by the user.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Expense entity."
        },
        "userId": {
          "type": "string",
          "description": "Reference to the User who made this expense."
        },
        "monthlyBudgetId": {
          "type": "string",
          "description": "Reference to the MonthlyBudget this expense falls under."
        },
        "expenseCategoryId": {
          "type": "string",
          "description": "Reference to the ExpenseCategory this expense belongs to."
        },
        "amount": {
          "type": "number",
          "description": "The monetary amount of the expense."
        },
        "description": {
          "type": "string",
          "description": "A brief description of the expense."
        },
        "date": {
          "type": "string",
          "description": "The date when the expense occurred.",
          "format": "date"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the expense record was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp when the expense record was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "monthlyBudgetId",
        "expenseCategoryId",
        "amount",
        "date",
        "createdAt"
      ]
    },
    "LearningGoal": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LearningGoal",
      "type": "object",
      "description": "Defines a user's specific learning goal.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "skill": { "type": "string" },
        "difficulty": { "type": "string" },
        "target": { "type": "number" },
        "completedCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "skill", "difficulty", "target", "createdAt"]
    },
    "DailyDiary": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "DailyDiary",
      "type": "object",
      "description": "Stores a user's personal diary entry for a specific day.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "whatIDidToday": { "type": "string" },
        "whatILearned": { "type": "string" },
        "challengesBlockers": { "type": "string" },
        "tomorrowsPlan": { "type": "string" },
        "mood": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "date", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Stores user profile information.",
          "params": [{ "name": "userId", "description": "User UID" }]
        }
      },
      {
        "path": "/users/{userId}/learningGoals/{goalId}",
        "definition": {
          "entityName": "LearningGoal",
          "schema": { "$ref": "#/backend/entities/LearningGoal" },
          "description": "Learning goals.",
          "params": [{ "name": "userId", "description": "User UID" }, { "name": "goalId", "description": "Goal ID" }]
        }
      },
      {
        "path": "/users/{userId}/expenseCategories/{categoryId}",
        "definition": {
          "entityName": "ExpenseCategory",
          "schema": { "$ref": "#/backend/entities/ExpenseCategory" },
          "description": "Expense categories.",
          "params": [{ "name": "userId", "description": "User UID" }, { "name": "categoryId", "description": "Category ID" }]
        }
      },
      {
        "path": "/users/{userId}/monthlyBudgets/{monthlyBudgetId}",
        "definition": {
          "entityName": "MonthlyBudget",
          "schema": { "$ref": "#/backend/entities/MonthlyBudget" },
          "description": "Monthly budget settings.",
          "params": [{ "name": "userId", "description": "User UID" }, { "name": "monthlyBudgetId", "description": "YYYYMM" }]
        }
      },
      {
        "path": "/users/{userId}/monthlyBudgets/{monthlyBudgetId}/fixedExpenses/{id}",
        "definition": {
          "entityName": "FixedExpense",
          "schema": { "$ref": "#/backend/entities/FixedExpense" },
          "description": "Fixed expenses.",
          "params": [{ "name": "userId", "description": "User UID" }, { "name": "monthlyBudgetId", "description": "YYYYMM" }, { "name": "id", "description": "Fixed ID" }]
        }
      },
      {
        "path": "/users/{userId}/monthlyBudgets/{monthlyBudgetId}/expenses/{id}",
        "definition": {
          "entityName": "Expense",
          "schema": { "$ref": "#/backend/entities/Expense" },
          "description": "Individual expenses.",
          "params": [{ "name": "userId", "description": "User UID" }, { "name": "monthlyBudgetId", "description": "YYYYMM" }, { "name": "id", "description": "Expense ID" }]
        }
      },
      {
        "path": "/users/{userId}/dailyDiaries/{date}",
        "definition": {
          "entityName": "DailyDiary",
          "schema": { "$ref": "#/backend/entities/DailyDiary" },
          "description": "Daily diary entries.",
          "params": [{ "name": "userId", "description": "User UID" }, { "name": "date", "description": "YYYY-MM-DD" }]
        }
      }
    ]
  }
}
