
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Shared Group Rules ---
    match /sharedGroups/{groupId} {
      allow create: if isSignedIn();
      allow get: if isSignedIn(); // Allow get for joining by ID
      allow list: if isSignedIn() && request.auth.uid in resource.data.memberUids;
      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.memberUids || // Existing member updating
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids', 'members'])) // New user joining
      );
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;

      match /expenses/{expenseId} {
        allow read, write: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/sharedGroups/$(groupId)).data.memberUids;
      }

      match /settlements/{settlementId} {
        allow read, write: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/sharedGroups/$(groupId)).data.memberUids;
      }
    }

    // --- User Rules ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create, update: if isOwner(userId);
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
