
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Shared Group Rules ---
    match /sharedGroups/{groupId} {
      
      // Helper to check membership via parent document
      function isGroupMember() {
        let groupPath = /databases/$(database)/documents/sharedGroups/$(groupId);
        return isSignedIn() && exists(groupPath) && (request.auth.uid in get(groupPath).data.memberUids);
      }

      allow create: if isSignedIn();
      allow get: if isSignedIn(); 
      allow list: if isSignedIn() && (request.auth.uid in resource.data.memberUids);
      allow update: if isSignedIn() && (
        (request.auth.uid in resource.data.memberUids) || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids', 'members'])) ||
        (resource.data.createdBy == request.auth.uid)
      );
      allow delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid);

      match /expenses/{expenseId} {
        allow list: if isSignedIn();
        allow get, write: if isGroupMember();
      }

      match /settlements/{settlementId} {
        allow list: if isSignedIn();
        allow get, write: if isGroupMember();
      }

      match /categories/{categoryId} {
        allow list: if isSignedIn();
        allow get, write: if isGroupMember();
      }
    }

    // --- Collection Group Matches (Global Queries) ---
    match /{path=**}/expenses/{expenseId} {
      // Allow user to query all their personal expenses and shared expenses
      allow list: if isSignedIn() && (
        path.indexOf('/users/' + request.auth.uid + '/') >= 0 ||
        (path.indexOf('/sharedGroups/') >= 0 && (request.auth.uid in get(/databases/$(database)/documents/sharedGroups/$(path[path.indexOf('sharedGroups') + 1])).data.memberUids))
      );
    }

    match /{path=**}/fixedExpenses/{id} {
      allow list: if isSignedIn() && (
        path.indexOf('/users/' + request.auth.uid + '/') >= 0
      );
    }

    // --- User Rules ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
