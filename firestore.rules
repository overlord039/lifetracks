
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Shared Group Rules ---
    match /sharedGroups/{groupId} {
      
      // Helper to check membership via parent document
      function isGroupMember() {
        let groupPath = /databases/$(database)/documents/sharedGroups/$(groupId);
        return isSignedIn() && exists(groupPath) && (request.auth.uid in get(groupPath).data.memberUids);
      }

      function isGroupCreator() {
        let groupPath = /databases/$(database)/documents/sharedGroups/$(groupId);
        return isSignedIn() && exists(groupPath) && (get(groupPath).data.createdBy == request.auth.uid);
      }

      allow create: if isSignedIn();
      allow get: if isSignedIn(); // Allow get for joining by ID
      allow list: if isSignedIn() && (request.auth.uid in resource.data.memberUids);
      allow update: if isSignedIn() && (
        (request.auth.uid in resource.data.memberUids) || // Existing member
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids', 'members'])) || // New member joining
        (resource.data.createdBy == request.auth.uid) // Creator managing members
      );
      allow delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid);

      match /expenses/{expenseId} {
        // Allow list for any signed-in user to avoid join race conditions.
        // Individual document access and writes still require confirmed membership.
        allow list: if isSignedIn();
        allow get, write: if isGroupMember();
      }

      match /settlements/{settlementId} {
        // Allow list for any signed-in user to avoid join race conditions.
        // Individual document access and writes still require confirmed membership.
        allow list: if isSignedIn();
        allow get, write: if isGroupMember();
      }
    }

    // --- User Rules ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
